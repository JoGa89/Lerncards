{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lerncards.local/schema/deck-import.schema.json",
  "title": "Lerncards Deck Import",
  "description": "JSON format accepted by DeckRepository.importDeckFromJson / DeckImport model.",
  "type": "object",
  "required": ["title", "cards"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Name des Kartensatzes"
    },
    "description": {
      "type": "string",
      "default": "",
      "description": "Optionale Beschreibung des Kartensatzes"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "description": "Vorderseite / Frage"
          },
          "answer": {
            "type": "string",
            "minLength": 1,
            "description": "Rückseite / Antwort"
          },
          "use_case": {
            "type": "string",
            "default": "",
            "description": "Optionaler Anwendungsfall, wird auf der Rückseite angezeigt"
          }
        },
        "additionalProperties": true
      },
      "description": "Mindestens eine Karte ist erforderlich"
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "title": "Englisch Basics",
      "description": "Wichtige Vokabeln",
      "cards": [
        {
          "question": "apple",
          "answer": "Apfel",
          "use_case": "I eat an apple every morning."
        }
      ]
    }
  ]
}
